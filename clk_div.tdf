SUBDESIGN clk_div
(
    clk      : INPUT;
    reset    : INPUT;
    tick_1ms : OUTPUT
)

VARIABLE
    cont[15..0] : DFF;

BEGIN

    cont[].clk = clk;
    cont[].clrn = !reset;

    IF cont[].q == 49999 THEN
        cont[].d = 0;
        tick_1ms = VCC;
    ELSE
        cont[].d = cont[].q + 1;
        tick_1ms = GND;
    END IF;

END;