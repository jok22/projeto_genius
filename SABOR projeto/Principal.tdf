INCLUDE "memoria.inc";
INCLUDE "random.inc";

SUBDESIGN Principal
(
    clock : INPUT;

    led[4..1] : OUTPUT
)

VARIABLE

    rng : random;
    mem : memoria;

BEGIN

    ----------------------------------------------------------------
    -- CLOCK
    ----------------------------------------------------------------

    rng.clock = clock;

    mem.clk = clock;

    ----------------------------------------------------------------
    -- LFSR → MEMÓRIA
    ----------------------------------------------------------------

    mem.random[] = rng.random_out[];

    ----------------------------------------------------------------
    -- HABILITA ESCRITA
    ----------------------------------------------------------------

    mem.wr = VCC;

    ----------------------------------------------------------------
    -- LEDs
    ----------------------------------------------------------------

    led[] = rng.led[];

END;